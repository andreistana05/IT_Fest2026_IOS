{
  "expo": {
    "projectId": "a3b2c1d4-5678-90ab-cdef-1234567890ab",
    "name": "FallDetector",
    "slug": "testapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "testapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-contacts",
        {
          "contactsPermission": "FallDetector needs access to your contacts to verify emergency contact numbers."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "FallDetector uses your location to let you share it with your contacts via SMS."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#e74c3c",
          "sounds": [],
          "mode": "production"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7611f775-85f9-45a8-baa8-7d6871d1f33e"
      }
    },
    "owner": "andreistana05"
  }
}
